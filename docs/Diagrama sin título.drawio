        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\n\npackage \&quot;CustomerService\&quot; {\n  [Customer Controller]\n  [Customer Service]\n  [Customer Repository]\n  database CustomerDB\n}\n\npackage \&quot;PassiveProductService\&quot; {\n  [Account Controller]\n  [Account Service]\n  [Account Repository]\n  database PassiveDB\n}\n\npackage \&quot;ActiveProductService\&quot; {\n  [Loan/Card Controller]\n  [Loan/Card Service]\n  [Loan/Card Repository]\n  database ActiveDB\n}\n\npackage \&quot;MovementService\&quot; {\n  [Movement Controller]\n  [Movement Service]\n  [Movement Repository]\n  database MovementDB\n}\n\nCustomerDB --&gt; [CustomerRepository]\nPassiveDB --&gt; [AccountRepository]\nActiveDB --&gt; [Loan/CardRepository]\nMovementDB --&gt; [MovementRepository]\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="DWHIHF5baGiWvRRY6au0-2">
